generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ReminderPriority {
  LOW
  MEDIUM
  HIGH
}

enum ReminderType {
  ONE_TIME
  RECURRING
  HABIT
  COUNTDOWN
  INBOX
}

enum ReminderStatus {
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum RecurrenceFrequency {
  DAILY
  WEEKLY
  MONTHLY
}

enum NotificationSourceType {
  REMINDER
  TIMETABLE
}

enum NotificationEventStatus {
  PENDING
  DELIVERED
  FAILED
}

enum ConversationMessageRole {
  USER
  ASSISTANT
  SYSTEM
}

enum IndexingStatus {
  PENDING
  INDEXED
  FAILED
  UNSUPPORTED
}

enum RetrievalSourceType {
  NOTE
  FILE
  MEMORY
}

enum MemoryArtifactStatus {
  PENDING
  READY
  FAILED
}

model User {
  id                 String           @id @default(cuid())
  clerkUserId        String           @unique
  telegramChatId     String?
  timezone           String           @default("Africa/Lagos")
  displayName        String?
  assistantProvider  String           @default("openrouter")
  assistantModel     String?
  transcriptionProvider String        @default("groq")
  transcriptionModel String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  reminders          Reminder[]
  timetableEntries   TimetableEntry[]
  notes              Note[]
  files              StoredFile[]
  retrievalChunks    RetrievalChunk[]
  memoryArtifacts    MemoryArtifact[]
  notificationEvents NotificationEvent[]
  conversations      Conversation[]
}

model Reminder {
  id                  String               @id @default(cuid())
  userId              String
  title               String
  description         String?
  type                ReminderType
  priority            ReminderPriority     @default(MEDIUM)
  category            String?
  tags                String[]
  dueAt               DateTime?
  recurrenceRule      String?
  recurrenceFrequency RecurrenceFrequency?
  recurrenceInterval  Int?
  recurrenceDays      Int[]
  recurrenceEndAt     DateTime?
  status              ReminderStatus       @default(ACTIVE)
  completedAt         DateTime?
  snoozedUntil        DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([userId, dueAt])
}

model TimetableEntry {
  id                  String   @id @default(cuid())
  userId              String
  subject             String
  location            String?
  lecturer            String?
  dayOfWeek           Int
  startTime           String
  endTime             String
  semesterStart       DateTime
  semesterEnd         DateTime
  reminderLeadMinutes Int      @default(30)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, dayOfWeek])
  @@index([semesterStart, semesterEnd])
}

model Note {
  id             String         @id @default(cuid())
  userId         String
  title          String
  content        String
  tags           String[]
  summary        String?
  indexingStatus IndexingStatus @default(PENDING)
  indexingError  String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, updatedAt])
}

model StoredFile {
  id               String         @id @default(cuid())
  userId           String
  blobUrl          String
  blobPath         String
  originalFilename String
  contentType      String
  byteSize         Int
  extractedText    String?
  extractionStatus IndexingStatus @default(PENDING)
  extractionError  String?
  indexingStatus   IndexingStatus @default(PENDING)
  indexingError    String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model RetrievalChunk {
  id                 String              @id @default(cuid())
  userId             String
  sourceType         RetrievalSourceType
  sourceId           String
  sourceTitle        String
  chunkIndex         Int
  content            String
  contentHash        String
  embeddingModel     String
  embeddingDimension Int
  embedding          Unsupported("vector")?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sourceType, sourceId, chunkIndex])
  @@index([userId, sourceType, sourceId])
  @@index([userId, updatedAt])
}

model MemoryArtifact {
  id                    String               @id @default(cuid())
  userId                String
  conversationId        String?
  kind                  String
  status                MemoryArtifactStatus @default(PENDING)
  summaryLevel          Int                  @default(1)
  sourceReference       String?
  title                 String?
  content               String
  structuredData        Json?
  tokenEstimate         Int                  @default(0)
  coveredFromMessageId  String?
  coveredToMessageId    String?
  coveredMessageCount   Int                  @default(0)
  sourceStartedAt       DateTime?
  sourceEndedAt         DateTime?
  indexingStatus        IndexingStatus       @default(PENDING)
  indexingError         String?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  user                  User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation          Conversation?        @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([userId, summaryLevel])
  @@index([userId, conversationId, summaryLevel])
  @@index([userId, status, updatedAt])
  @@index([conversationId, sourceStartedAt])
}

model Conversation {
  id                         String                @id @default(cuid())
  userId                     String
  title                      String?
  source                     String                @default("web")
  latestMessageAt            DateTime?
  latestSummarizedMessageAt  DateTime?
  summaryBackfilledAt        DateTime?
  createdAt                  DateTime              @default(now())
  updatedAt                  DateTime              @updatedAt
  user                       User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages                   ConversationMessage[]
  memoryArtifacts            MemoryArtifact[]

  @@index([userId, updatedAt])
}

model ConversationMessage {
  id                String                  @id @default(cuid())
  conversationId    String
  role              ConversationMessageRole
  content           String
  source            String?
  structuredData    Json?
  tokenEstimate     Int                     @default(0)
  summarizedAt      DateTime?
  createdAt         DateTime                @default(now())
  conversation      Conversation            @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([conversationId, summarizedAt, createdAt])
}

model NotificationEvent {
  id                 String                  @id @default(cuid())
  userId             String
  reminderId         String?
  timetableEntryId   String?
  sourceType         NotificationSourceType
  sourceOccurrenceKey String?
  transport          String
  dedupeKey          String                  @unique
  status             NotificationEventStatus @default(PENDING)
  providerMessageId  String?
  failureReason      String?
  deliveredAt        DateTime?
  lastAttemptAt      DateTime?
  actionedAt         DateTime?
  createdAt          DateTime                @default(now())
  user               User                    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([status, createdAt])
}
